<script>
  // ---- Header scroll state ----
  const header = document.getElementById('siteHeader');
  const onScroll = () => {
    if (window.scrollY > 24) header.classList.add('scrolled');
    else header.classList.remove('scrolled');
  };
  window.addEventListener('scroll', onScroll, {passive:true});
  onScroll();

  // ---- Reveal on scroll ----
  const io = new IntersectionObserver((entries) => {
    entries.forEach(e => {
      if (e.isIntersecting) {
        e.target.classList.add('in');
        io.unobserve(e.target);
      }
    });
  }, {threshold: 0.12, rootMargin: '0px 0px -8% 0px'});
  document.querySelectorAll('.reveal').forEach(el => io.observe(el));

  // ---- Smooth scroll for in-page anchors ----
  document.querySelectorAll('a[href^="#"]').forEach(a => {
    a.addEventListener('click', (e) => {
      const id = a.getAttribute('href');
      if (id.length > 1) {
        const target = document.querySelector(id);
        if (target) {
          e.preventDefault();
          window.scrollTo({top: target.getBoundingClientRect().top + window.scrollY - 60, behavior:'smooth'});
        }
      }
    });
  });
</script>

<!-- ============ TWEAKS PANEL (founders) ============ -->
<aside class="ob-tweaks" id="obTweaks" aria-label="Tweaks">
  <header>
    <h3>Tweaks</h3>
    <button type="button" id="obTweaksClose" aria-label="Close tweaks">×</button>
  </header>
  <div class="body">
    <div class="group">
      <div class="group-title">Team photo</div>
      <label>
        <span class="lbl">Photo of Joshua &amp; Valeria</span>
        <div class="file-row">
          <input type="url" placeholder="Paste image URL or upload" data-tw="duoPhoto" />
          <button type="button" class="file-btn" data-upload="duoPhoto">Upload</button>
        </div>
        <button type="button" class="clear-btn" data-clear="duoPhoto" style="margin-top:6px;">Clear photo</button>
      </label>
    </div>
    <div class="group">
      <div class="group-title">Founder · Joshua Chavez</div>
      <label>
        <span class="lbl">Name</span>
        <input type="text" data-tw="founderName" />
      </label>
      <label>
        <span class="lbl">Role</span>
        <input type="text" data-tw="founderRole" />
      </label>
    </div>
    <div class="group">
      <div class="group-title">Co-Founder · Valeria Castro-Chavez</div>
      <label>
        <span class="lbl">Name</span>
        <input type="text" data-tw="cofounderName" />
      </label>
      <label>
        <span class="lbl">Role</span>
        <input type="text" data-tw="cofounderRole" />
      </label>
    </div>
    <div class="hint">Photos are stored locally in your browser. For permanent photos, host the image and paste its URL.</div>
  </div>
</aside>
<input type="file" id="obTweaksFile" accept="image/*" style="display:none;" />

<script>
  // -------- Tweaks: founders block --------
  (function(){
    var TWEAK_DEFAULS = /*EDITMODE-BEGIN*/{
      "founderName": "Joshua Chavez",
      "founderRole": "Founder · Creative Direction",
      "cofounderName": "Valeria Castro-Chavez",
      "cofounderRole": "Co-Founder · Marketing Director",
      "duoPhoto": "assets/founders.jpg"
    }/*EDITMODE-END*/;

    var STORAGE_KEY = 'ob-tweaks-founders';
    function load(){
      try { return Object.assign({}, TWEAK_DEFAULS, JSON.parse(localStorage.getItem(STORAGE_KEY) || '{}')); }
      catch(e){ return Object.assign({}, TWEAK_DEFAULS); }
    }
    function save(state){ localStorage.setItem(STORAGE_KEY, JSON.stringify(state)); }

    var state = load();
    var panel = document.getElementById('obTweaks');
    var closeBtn = document.getElementById('obTweaksClose');
    var fileInput = document.getElementById('obTweaksFile');
    var pendingUploadKey = null;

    function applyToDom(){
      // Names + roles
      var pairs = [
        ['founderName',   '[data-name="founder"]'],
        ['founderRole',   '[data-role="founder"]'],
        ['cofounderName', '[data-name="cofounder"]'],
        ['cofounderRole', '[data-role="cofounder"]']
      ];
      pairs.forEach(function(p){
        var el = document.querySelector(p[1]);
        if (el) el.textContent = state[p[0]] || '';
      });
      // Photo (single shared portrait of both)
      (function(){
        var box = document.querySelector('.team-photo[data-portrait="duo"]');
        if (!box) return;
        var img = box.querySelector('.team-photo-img');
        var url = state.duoPhoto;
        if (url){
          img.src = url;
          box.classList.add('has-image');
        } else {
          img.removeAttribute('src');
          box.classList.remove('has-image');
        }
      })();
    }

    function syncInputs(){
      panel.querySelectorAll('[data-tw]').forEach(function(inp){
        var k = inp.getAttribute('data-tw');
        inp.value = state[k] || '';
      });
    }

    function update(key, value){
      state[key] = value;
      save(state);
      applyToDom();
      // Persist to host (when running in editor) — only persist non-photo keys
      // (photos can be huge data URLs; keep them local-only).
      try {
        var safeEdits = {};
        ['founderName','founderRole','cofounderName','cofounderRole'].forEach(function(k){
          if (k === key) safeEdits[k] = value;
        });
        if (Object.keys(safeEdits).length){
          window.parent.postMessage({type:'__edit_mode_set_keys', edits: safeEdits}, '*');
        }
      } catch(e){}
    }

    // Wire inputs
    panel.querySelectorAll('input[data-tw]').forEach(function(inp){
      inp.addEventListener('input', function(){
        update(inp.getAttribute('data-tw'), inp.value);
      });
    });
    // Wire upload buttons
    panel.querySelectorAll('[data-upload]').forEach(function(btn){
      btn.addEventListener('click', function(){
        pendingUploadKey = btn.getAttribute('data-upload');
        fileInput.click();
      });
    });
    fileInput.addEventListener('change', function(){
      var file = fileInput.files && fileInput.files[0];
      if (!file || !pendingUploadKey) return;
      var reader = new FileReader();
      reader.onload = function(e){
        update(pendingUploadKey, e.target.result);
        var inp = panel.querySelector('[data-tw="'+pendingUploadKey+'"]');
        if (inp) inp.value = e.target.result;
        pendingUploadKey = null;
        fileInput.value = '';
      };
      reader.readAsDataURL(file);
    });
    // Wire clear buttons
    panel.querySelectorAll('[data-clear]').forEach(function(btn){
      btn.addEventListener('click', function(){
        var k = btn.getAttribute('data-clear');
        update(k, '');
        var inp = panel.querySelector('[data-tw="'+k+'"]');
        if (inp) inp.value = '';
      });
    });

    // Open/close (host protocol)
    function open(){ panel.classList.add('open'); }
    function close(){
      panel.classList.remove('open');
      try { window.parent.postMessage({type:'__edit_mode_dismissed'}, '*'); } catch(e){}
    }
    closeBtn.addEventListener('click', close);
    window.addEventListener('message', function(e){
      var d = e && e.data;
      if (!d || !d.type) return;
      if (d.type === '__activate_edit_mode') open();
      if (d.type === '__deactivate_edit_mode') panel.classList.remove('open');
    });
    try { window.parent.postMessage({type:'__edit_mode_available'}, '*'); } catch(e){}

    // Initialize
    syncInputs();
    applyToDom();
  })();
</script>

</body>
</html>

